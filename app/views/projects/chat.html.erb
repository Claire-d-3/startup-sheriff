<div class="container py-4 chat-page">
  <div class="chat-header">
    <div>
      <h1 id="chat_title"><%= @project.title %></h1>
      <%= link_to "Cards of project", project_path(@chat.project), class: "btn btn-outline-secondary" %>
    </div>
  </div>

  <div id="messages" class="chat-messages">
    <% @chat.messages.each do |message| %>
      <% if message.role == "user" %>
        <div class="chat-row chat-row-user">
          <div class="chat-bubble chat-bubble-user">
            <%= simple_format(h(message.content)) %>
          </div>
        </div>
      <% elsif message.role == "assistant" %>
        <div class="chat-row chat-row-assistant">
          <div class="chat-bubble chat-bubble-assistant">
            <%= markdown(message.content) %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <div id="new_message_container" class="chat-input-container">
    <%= simple_form_for [@project, @message],
      html: {
        class: "chat-input-form",
        data: {
          controller: "chat-form"
        }
      } do |f| %>

      <label class="form-label">Ask a question</label>

      <div class="chat-input-row">
        <%= f.input :content,
          label: false,
          required: true,
          placeholder: "What's your startup idea?",
          wrapper_html: { class: "chat-input-wrapper" },
          input_html: {
            rows: 2,
            class: "chat-textarea",
            data: {
              action: "keydown->chat-form#submit"
            }
          } %>

        <%= f.button :submit, "Ask Sheriff", class: "btn btn-primary chat-submit-button" %>
      </div>
    <% end %>
  </div>
</div>
