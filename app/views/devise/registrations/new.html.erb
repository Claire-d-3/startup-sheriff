<div class="ss-auth-page">
  <%= render "shared/navbar" %>

  <div class="ss-cloud ss-cloud-one"></div>
  <div class="ss-cloud ss-cloud-two"></div>

  <div class="container ss-auth-container">
    <div class="ss-auth-card">
      <div class="ss-auth-character-wrap">
        <%= image_tag "sheriff_charakter.jpg", class: "ss-auth-character", alt: "Startup Sheriff" %>
        <div class="ss-lasso-ring"></div>
      </div>

      <h1>Join Startup Sheriff</h1>

      <p>
        Create your account and start validating your startup idea.
      </p>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "ss-auth-form" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="mb-3">
          <%= f.text_field :first_name,
            autofocus: true,
            autocomplete: "given-name",
            placeholder: "First name",
            class: "form-control ss-input" %>
        </div>

        <div class="mb-3">
          <%= f.email_field :email,
            autocomplete: "email",
            placeholder: "Email",
            class: "form-control ss-input" %>
        </div>

        <div class="mb-3">
          <%= f.password_field :password,
            autocomplete: "new-password",
            placeholder: "Password",
            class: "form-control ss-input" %>
        </div>

        <%= f.submit "Create account", class: "btn ss-btn-primary w-100" %>
      <% end %>

      <div class="ss-auth-footer">
        Already have an account?
        <%= link_to "Log in", new_user_session_path %>
      </div>
    </div>
  </div>
</div>
