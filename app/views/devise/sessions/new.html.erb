<div class="ss-auth-page">
  <%= render "shared/navbar" %>

  <div class="ss-cloud ss-cloud-one"></div>
  <div class="ss-cloud ss-cloud-two"></div>

  <div class="container ss-auth-container">
    <div class="ss-auth-card">
      <div class="ss-auth-badge">
        ★
      </div>

      <h1>Welcome back</h1>

      <p>
        Log in and continue validating your startup ideas.
      </p>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "ss-auth-form" }) do |f| %>
        <div class="mb-3">
          <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            placeholder: "Email",
            class: "form-control ss-input" %>
        </div>

        <div class="mb-3">
          <%= f.password_field :password,
            autocomplete: "current-password",
            placeholder: "Password",
            class: "form-control ss-input" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="form-check text-start mb-3">
            <%= f.check_box :remember_me, class: "form-check-input" %>
            <%= f.label :remember_me, class: "form-check-label" %>
          </div>
        <% end %>

        <%= f.submit "Log in", class: "btn ss-btn-primary w-100" %>
      <% end %>

      <div class="ss-auth-footer">
        No account yet?
        <%= link_to "Create account", new_user_registration_path %>
      </div>
    </div>
  </div>
</div>
